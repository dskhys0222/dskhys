{
    "name": "dskhys",
    "private": true,
    "engines": {
        "node": "24",
        "npm": "npmではなくpnpmを使用してください",
        "pnpm": "11"
    },
    "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
    "scripts": {
        "lint": "biome check .",
        "format": "biome check --write .",
        "test": "pnpm api test && pnpm web test && pnpm budget test && pnpm portfolio test && pnpm mf-scraper test",
        "build": "pnpm api build && pnpm web build && pnpm budget build && pnpm portfolio build && pnpm mf-scraper build",
        "check": "pnpm format && pnpm test && pnpm build",
        "api": "pnpm --filter @dskhys/api",
        "web": "pnpm --filter @dskhys/web",
        "budget": "pnpm --filter @dskhys/budget",
        "portfolio": "pnpm --filter @dskhys/portfolio",
        "mf-scraper": "pnpm --filter @dskhys/mf-scraper"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.3.10",
        "@semantic-release/changelog": "^6.0.3",
        "@semantic-release/github": "^12.0.2",
        "@semantic-release/npm": "^13.1.3",
        "semantic-release": "^25.0.2"
    }
}
